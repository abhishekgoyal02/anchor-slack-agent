# ==========================================================
# Anchor Slack Agent
# Environment Variables
# ==========================================================
#
# Copy this file to ".env"
# and replace all placeholder values.
#
# Never commit your ".env" file.
#
# ==========================================================


# ==========================================================
# Google Gemini
# ==========================================================

# Required
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# Optional
# Default: gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash


# ==========================================================
# GitHub Integration
# ==========================================================

# Required for automatic GitHub Issue creation
GITHUB_TOKEN=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN
GITHUB_OWNER=YOUR_GITHUB_USERNAME_OR_ORGANIZATION
GITHUB_REPO=YOUR_GITHUB_REPOSITORY


# ==========================================================
# Slack Configuration
# ==========================================================
#
# If you use:
#
#     slack run
#
# Slack CLI automatically injects these variables.
#
# Uncomment ONLY when running manually
# (npm start / node app.js).
#

# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET


# ==========================================================
# OAuth Mode (Optional)
# ==========================================================
#
# Required only when running:
#
#     node app-oauth.js
#

# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect


# ==========================================================
# Optional Configuration
# ==========================================================

# Custom Slack API URL
# SLACK_API_URL=https://slack.com/api


# ==========================================================
# Synchronization
# ==========================================================
#
# Loop Closure polling interval
#
# Development:
# 30000 (30 seconds)
#
# Production:
# 300000 (5 minutes)
#

# LOOP_CLOSURE_INTERVAL_MS=30000


# ==========================================================
# Logging
# ==========================================================

# NODE_ENV=development
# LOG_LEVEL=debug


# ==========================================================
# Database (Optional)
# ==========================================================

# DATABASE_PATH=./storage/anchor.db
